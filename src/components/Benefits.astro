---
const benefits = [
  {
    icon: '⏱️',
    title: 'Atención Inmediata',
    description: 'Sin esperas innecesarias. Consulta disponible en menos de 15 minutos.'
  },
  {
    icon: '💰',
    title: 'Ahorro de Tiempo y Dinero',
    description: 'Evita traslados y consultorios. Precios transparentes sin costos ocultos.'
  },
  {
    icon: '🔒',
    title: 'Totalmente Seguro',
    description: 'Plataforma encriptada que cumple con todas las normativas de privacidad médica.'
  },
  {
    icon: '📱',
    title: 'Desde Cualquier Dispositivo',
    description: 'Accede desde móvil, tablet o computadora. Compatible con todos los sistemas.'
  },
  {
    icon: '🌍',
    title: 'Disponible 24/7',
    description: 'Atención médica cuando la necesites, incluyendo fines de semana y festivos.'
  },
  {
    icon: '📋',
    title: 'Historial Digital',
    description: 'Todas tus consultas, recetas y análisis organizados en tu perfil personal.'
  }
];
---

<section id="beneficios" class="benefits">
  <div class="container">
    <div class="section-header">
      <h2>Por Qué Elegir Médico Online</h2>
      <p>Ventajas de la telemedicina moderna</p>
    </div>
    <div class="benefits-grid">
      {benefits.map((benefit) => (
        <div class="benefit-card">
          <div class="benefit-icon">{benefit.icon}</div>
          <h3>{benefit.title}</h3>
          <p>{benefit.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .benefits {
    background-color: var(--color-light);
  }

  .section-header {
    text-align: center;
    margin-bottom: var(--spacing-lg);
  }

  .section-header h2 {
    color: var(--color-dark);
    margin-bottom: var(--spacing-sm);
  }

  .section-header p {
    color: var(--color-gray);
    font-size: 1.125rem;
  }

  .benefits-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: var(--spacing-md);
  }

  .benefit-card {
    background-color: var(--color-white);
    padding: var(--spacing-md);
    border-radius: var(--border-radius);
    box-shadow: var(--shadow-sm);
    transition: var(--transition);
    text-align: center;
  }

  .benefit-card:hover {
    transform: scale(1.05);
    box-shadow: var(--shadow-md);
  }

  .benefit-icon {
    font-size: 3.5rem;
    margin-bottom: var(--spacing-sm);
  }

  .benefit-card h3 {
    color: var(--color-dark);
    margin-bottom: var(--spacing-sm);
  }

  .benefit-card p {
    color: var(--color-gray);
    line-height: 1.6;
  }

  @media (max-width: 768px) {
    .benefits-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
