---

<section class="hero">
  <div class="container">
    <div class="hero-content">
      <div class="hero-text">
        <h1>Consulta Médica Online en Minutos</h1>
        <p class="hero-subtitle">
          Accede a atención médica profesional desde cualquier lugar. 
          Consultas por videollamada las 24 horas, los 7 días de la semana.
        </p>
        <div class="hero-buttons">
          <a href="#contacto" class="button button-primary">Comenzar Ahora</a>
          <a href="#como-funciona" class="button button-secondary">Ver Cómo Funciona</a>
        </div>
        <div class="hero-stats">
          <div class="stat">
            <strong>10,000+</strong>
            <span>Pacientes Atendidos</span>
          </div>
          <div class="stat">
            <strong>500+</strong>
            <span>Médicos Certificados</span>
          </div>
          <div class="stat">
            <strong>98%</strong>
            <span>Satisfacción</span>
          </div>
        </div>
      </div>
      <div class="hero-image">
        <div class="image-placeholder">
          <svg width="100%" height="100%" viewBox="0 0 600 600" fill="none" xmlns="http://www.w3.org/2000/svg">
            <rect width="600" height="600" rx="20" fill="var(--color-light)"/>
            <circle cx="300" cy="250" r="80" fill="var(--color-primary)" opacity="0.2"/>
            <rect x="200" y="200" width="200" height="200" rx="100" fill="var(--color-primary)" opacity="0.3"/>
            <path d="M250 280L280 310L350 240" stroke="var(--color-secondary)" stroke-width="12" stroke-linecap="round" stroke-linejoin="round"/>
            <circle cx="300" cy="280" r="60" stroke="var(--color-primary)" stroke-width="8" fill="none"/>
          </svg>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    background: linear-gradient(135deg, #f5f7fa 0%, #e8f4f8 100%);
    padding: var(--spacing-xl) 0;
    margin-top: -1rem;
  }

  .hero-content {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--spacing-lg);
    align-items: center;
  }

  .hero-text h1 {
    color: var(--color-dark);
    margin-bottom: var(--spacing-md);
  }

  .hero-subtitle {
    font-size: 1.25rem;
    color: var(--color-gray);
    margin-bottom: var(--spacing-md);
  }

  .hero-buttons {
    display: flex;
    gap: var(--spacing-sm);
    margin-bottom: var(--spacing-lg);
    flex-wrap: wrap;
  }

  .hero-stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--spacing-md);
    margin-top: var(--spacing-lg);
  }

  .stat {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-xs);
  }

  .stat strong {
    font-size: 2rem;
    color: var(--color-primary);
  }

  .stat span {
    font-size: 0.875rem;
    color: var(--color-gray);
  }

  .hero-image {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .image-placeholder {
    width: 100%;
    max-width: 500px;
    border-radius: 20px;
    overflow: hidden;
    box-shadow: var(--shadow-lg);
  }

  @media (max-width: 768px) {
    .hero {
      padding: var(--spacing-lg) 0;
    }

    .hero-content {
      grid-template-columns: 1fr;
      gap: var(--spacing-md);
    }

    .hero-image {
      order: -1;
    }

    .hero-stats {
      grid-template-columns: 1fr;
      gap: var(--spacing-sm);
    }

    .hero-buttons {
      flex-direction: column;
    }

    .hero-buttons .button {
      width: 100%;
      text-align: center;
    }
  }
</style>
